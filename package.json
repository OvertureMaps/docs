{
  "name": "overture-documentation",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "npm run docusaurus start",
    "build": "npm run docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint 'docs/**/*.md' 'docs/**/*.mdx' 'blog/**/*.md' 'blog/**/*.mdx' --ignore node_modules",
    "lint:md:fix": "markdownlint 'docs/**/*.md' 'docs/**/*.mdx' 'blog/**/*.md' 'blog/**/*.mdx' --ignore node_modules --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/faster": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.0",
    "maplibre-gl": "^5.22.0",
    "pmtiles": "^4.3.0",
    "prism-react-renderer": "^2.1.0",
    "raw-loader": "^4.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/types": "^3.10.0",
    "@eslint/js": "^10.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
